blueprint:
  name: "Botão Cenas (Max Dinâmico)"
  description: "Cicla cenas usando o valor máximo configurado no input_number."
  domain: automation
  input:
    button_id_input:
      name: ID do Botão
    counter_helper:
      name: Ajudante de Contador
      selector: { entity: { domain: input_number } }
    scene_1:
      name: Cena 1
      selector: { entity: { domain: scene } }
    scene_2:
      name: Cena 2
      default: []
      selector: { entity: { domain: scene } }
    scene_3:
      name: Cena 3
      default: []
      selector: { entity: { domain: scene } }
    scene_4:
      name: Cena 4
      default: []
      selector: { entity: { domain: scene } }
    scene_5:
      name: Cena 5
      default: []
      selector: { entity: { domain: scene } }
    scene_off:
      name: Cena Desligar
      selector: { entity: { domain: scene } }
    tempo_esquecimento:
      name: Tempo de Esquecimento
      default: "01:00:00"

mode: queued
max: 10

trigger:
  - platform: event
    event_type: esphome.esp_click_event
    id: "clique"
  # Gatilho de esquecimento simplificado: se o contador estiver acima de 0 por X tempo
  - platform: numeric_state
    entity_id: !input counter_helper
    above: 0
    for: !input tempo_esquecimento
    id: "esquecimento"

action:
  - variables:
      entidade_contador: !input counter_helper
      # Puxa o valor máximo definido no ajudante
      valor_max_ajudante: "{{ state_attr(entidade_contador, 'max') | int(5) }}"
      evento_botao: "{{ trigger.event.data.button if trigger.platform == 'event' else 'nenhum' }}"
      evento_tipo: "{{ trigger.event.data.type if trigger.platform == 'event' else 'nenhum' }}"
      id_configurado: !input button_id_input

  # --- AÇÃO DO TEMPO DE ESQUECIMENTO ---
  - if:
      - condition: template
        value_template: "{{ trigger.id == 'esquecimento' }}"
    then:
      - service: scene.turn_on
        target: {entity_id: !input scene_off}
      - service: input_number.set_value
        target: {entity_id: !input counter_helper}
        data: {value: 0}
      - stop: "Esquecimento: Cena desligada."

  # --- FILTRO DE ID ---
  - condition: template
    value_template: "{{ evento_botao == id_configurado }}"

  - choose:
      # --- CLIQUE CURTO ---
      - conditions: "{{ evento_tipo == 'curto' }}"
        sequence:
          - service: input_number.set_value
            target: { entity_id: !input counter_helper }
            data:
              value: >
                {% set atual = states(entidade_contador) | int(0) %}
                {# Reseta para 0 se atingir o máximo configurado no ajudante #}
                {{ 0 if atual >= valor_max_ajudante else atual + 1 }}
          
          - delay: "00:00:00.05"
          
          - choose:
              - conditions: "{{ is_state(entidade_contador, '1.0') }}"
                sequence: [{service: scene.turn_on, target: {entity_id: !input scene_1}}]
              - conditions: "{{ is_state(entidade_contador, '2.0') }}"
                sequence: [{service: scene.turn_on, target: {entity_id: !input scene_2}}]
              - conditions: "{{ is_state(entidade_contador, '3.0') }}"
                sequence: [{service: scene.turn_on, target: {entity_id: !input scene_3}}]
              - conditions: "{{ is_state(entidade_contador, '4.0') }}"
                sequence: [{service: scene.turn_on, target: {entity_id: !input scene_4}}]
              - conditions: "{{ is_state(entidade_contador, '5.0') }}"
                sequence: [{service: scene.turn_on, target: {entity_id: !input scene_5}}]
            default:
              - service: scene.turn_on
                target: {entity_id: !input scene_off}

      # --- CLIQUE LONGO ---
      - conditions: "{{ evento_tipo == 'longo' }}"
        sequence:
          - service: scene.turn_on
            target: {entity_id: !input scene_off}
          - service: input_number.set_value
            target: {entity_id: !input counter_helper}
            data: {value: 0}
