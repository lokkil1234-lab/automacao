blueprint:
  name: "Botão Cenas + Sensor (Versão Final Sem Erros)"
  domain: automation
  input:
    button_id_input: { name: ID do Botão }
    counter_helper: { name: Ajudante de Contador, selector: { entity: { domain: counter } } }
    scene_1: { name: Cena 1, selector: { entity: { domain: scene } } }
    scene_2: { name: Cena 2, default: [], selector: { entity: { domain: scene } } }
    scene_3: { name: Cena 3, default: [], selector: { entity: { domain: scene } } }
    scene_4: { name: Cena 4, default: [], selector: { entity: { domain: scene } } }
    scene_5: { name: Cena 5, default: [], selector: { entity: { domain: scene } } }
    scene_off: { name: Cena Desligar (Botão), selector: { entity: { domain: scene } } }
    tempo_esquecimento: { name: Tempo de Esquecimento, default: "01:00:00", selector: { duration: {} } }
    helper_inibicao: { name: Helper de Inibição, selector: { entity: { domain: input_boolean } } }
    tempo_inibicao: { name: Tempo de Liberação, default: 10, selector: { number: { min: 0, max: 3600, mode: box } } }
    sensor_id_input: { name: ID do Sensor }
    tempo_ligada: { name: Tempo de Permanência (Sensor), default: 60, selector: { number: { min: 1, max: 3600, mode: box } } }
    scene_dia: { name: Cena Dia, selector: { entity: { domain: scene } } }
    scene_noite: { name: Cena Noite, selector: { entity: { domain: scene } } }
    scene_madrugada: { name: Cena Madrugada, selector: { entity: { domain: scene } } }
    scene_off_sensor: { name: Cena Desligar (Sensor), selector: { entity: { domain: scene } } }
    dia_inicio: { name: Início do Dia, default: "06:00:00", selector: { time: {} } }
    dia_fim: { name: Fim do Dia, default: "18:00:00", selector: { time: {} } }
    noite_inicio: { name: Início da Noite, default: "18:00:01", selector: { time: {} } }
    noite_fim: { name: Fim da Noite, default: "23:59:59", selector: { time: {} } }

mode: parallel
max: 10

trigger:
  - platform: event
    event_type: esphome.esp_click_event
    id: "clique_ou_sensor"
  - platform: numeric_state
    entity_id: !input counter_helper
    above: 0
    for: !input tempo_esquecimento
    id: "esquecimento"

action:
  - variables:
      # Mapeamento de IDs e Inputs para variáveis (evita o erro do '!')
      id_botao: !input button_id_input
      id_sensor: !input sensor_id_input
      entidade_inibicao: !input helper_inibicao
      contador: !input counter_helper
      
      # Horários mapeados
      h_ini_dia: !input dia_inicio
      h_fim_dia: !input dia_fim
      h_ini_noite: !input noite_inicio
      h_fim_noite: !input noite_fim
      
      # Dados do evento
      evento_id: "{{ trigger.event.data.button if trigger.platform == 'event' else 'nenhum' }}"
      evento_tipo: "{{ trigger.event.data.type if trigger.platform == 'event' else 'nenhum' }}"
      agora: "{{ now().strftime('%H:%M:%S') }}"

  - choose:
      # --- 1. ESQUECIMENTO ---
      - conditions:
          - condition: template
            value_template: "{{ trigger.id == 'esquecimento' }}"
        sequence:
          - service: scene.turn_on
            target: {entity_id: !input scene_off}
          - service: counter.reset
            target: {entity_id: !input counter_helper}
          - delay: {seconds: !input tempo_inibicao}
          - service: input_boolean.turn_off
            target: {entity_id: !input helper_inibicao}

      # --- 2. CLIQUE DO BOTÃO ---
      - conditions:
          - condition: template
            value_template: "{{ evento_id == id_botao }}"
        sequence:
          - service: input_boolean.turn_on
            target: {entity_id: !input helper_inibicao}
          - choose:
              - conditions:
                  - condition: template
                    value_template: "{{ evento_tipo == 'curto' }}"
                sequence:
                  - choose:
                      - conditions:
                          - condition: template
                            value_template: "{{ states(contador) | int >= state_attr(contador, 'maximum') | int(5) }}"
                        sequence: [{service: counter.reset, target: {entity_id: !input counter_helper}}]
                    default: [{service: counter.increment, target: {entity_id: !input counter_helper}}]
                  - delay: "00:00:00.05"
                  - choose:
                      - conditions: [{condition: template, value_template: "{{ is_state(contador, '1') }}"}]
                        sequence: [{service: scene.turn_on, target: {entity_id: !input scene_1}}]
                      - conditions: [{condition: template, value_template: "{{ is_state(contador, '2') }}"}]
                        sequence: [{service: scene.turn_on, target: {entity_id: !input scene_2}}]
                      - conditions: [{condition: template, value_template: "{{ is_state(contador, '3') }}"}]
                        sequence: [{service: scene.turn_on, target: {entity_id: !input scene_3}}]
                      - conditions: [{condition: template, value_template: "{{ is_state(contador, '4') }}"}]
                        sequence: [{service: scene.turn_on, target: {entity_id: !input scene_4}}]
                      - conditions: [{condition: template, value_template: "{{ is_state(contador, '5') }}"}]
                        sequence: [{service: scene.turn_on, target: {entity_id: !input scene_5}}]
                    default: 
                      - service: scene.turn_on
                        target: {entity_id: !input scene_off}
                      - delay: {seconds: !input tempo_inibicao}
                      - service: input_boolean.turn_off
                        target: {entity_id: !input helper_inibicao}
              - conditions:
                  - condition: template
                    value_template: "{{ evento_tipo == 'longo' }}"
                sequence:
                  - service: scene.turn_on
                    target: {entity_id: !input scene_off}
                  - service: counter.reset
                    target: {entity_id: !input counter_helper}
                  - delay: {seconds: !input tempo_inibicao}
                  - service: input_boolean.turn_off
                    target: {entity_id: !input helper_inibicao}

      # --- 3. SENSOR PERÍODOS ---
      - conditions:
          - condition: template
            value_template: "{{ evento_id == id_sensor and evento_tipo == 'curto' and is_state(entidade_inibicao, 'off') }}"
        sequence:
          - choose:
              - conditions:
                  - condition: template
                    value_template: "{{ agora >= h_ini_dia and agora <= h_fim_dia }}"
                sequence: [{service: scene.turn_on, target: {entity_id: !input scene_dia}}]
              - conditions:
                  - condition: template
                    value_template: "{{ agora >= h_ini_noite and agora <= h_fim_noite }}"
                sequence: [{service: scene.turn_on, target: {entity_id: !input scene_noite}}]
            default: [{service: scene.turn_on, target: {entity_id: !input scene_madrugada}}]
          - delay: {seconds: !input tempo_ligada}
          - service: scene.turn_on
            target: {entity_id: !input scene_off_sensor}
