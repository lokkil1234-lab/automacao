blueprint:
  name: "Gerenciador de Ambiente Pro (Sensores + Botão Cenas)"
  description: "Gerencia ocupação via sensores e controle manual via botão com ciclos de cenas e tempos de inibição."
  domain: automation
  input:
    # --- HARDWARE ---
    button_id_input:
      name: ID do Botão (ESPHome)
      description: "ID enviado pelo botão para controle de cenas"
    motion_sensors:
      name: Sensores de Movimento
      description: "Selecione um ou mais sensores binários do ambiente"
      selector:
        entity:
          domain: binary_sensor
          multiple: true
    # --- AUXILIARES (HELPERS) ---
    counter_helper:
      name: Ajudante de Contador
      selector: { entity: { domain: input_number } }
    block_helper:
      name: Bloqueio do Sensor (Input Boolean)
      description: "Crie um input_boolean para este ambiente para gerenciar o modo manual/automático."
      selector: { entity: { domain: input_boolean } }
    # --- CONFIGURAÇÕES ---
    max_scenes:
      name: Quantidade de Cenas
      description: "Quantas cenas o botão deve alternar (1 a 5)"
      default: 3
      selector:
        number: { min: 1, max: 5 }
    tempo_sensor:
      name: Tempo do Sensor (Auto-Off)
      default: 60
      selector: { number: { min: 5, max: 3600, unit_of_measurement: seconds } }
    tempo_esquecimento:
      name: Tempo de Esquecimento (Botão)
      default: "01:00:00"
    tempo_inibicao:
      name: Tempo de Inibição
      description: "Tempo para sair do ambiente sem que o sensor religue a luz após o OFF."
      default: 10
      selector: { number: { min: 0, max: 60, unit_of_measurement: seconds } }
    # --- CENAS ---
    scene_dia:
      name: Cena Dia (Sensor)
      selector: { entity: { domain: scene } }
    scene_noite:
      name: Cena Noite (Sensor)
      selector: { entity: { domain: scene } }
    scene_madrugada:
      name: Cena Madrugada (Sensor)
      selector: { entity: { domain: scene } }
    scene_1:
      name: Cena 1 (Botão)
      selector: { entity: { domain: scene } }
    scene_2:
      name: Cena 2 (Botão)
      selector: { entity: { domain: scene } }
    scene_3:
      name: Cena 3 (Botão)
      selector: { entity: { domain: scene } }
    scene_4:
      name: Cena 4 (Botão)
      selector: { entity: { domain: scene } }
    scene_5:
      name: Cena 5 (Botão)
      selector: { entity: { domain: scene } }
    scene_off:
      name: Cena Desligar
      selector: { entity: { domain: scene } }
    # --- PERÍODOS ---
    dia_inicio:
      name: Início do Dia
      default: "06:00:00"
      selector: { time: {} }
    dia_fim:
      name: Fim do Dia
      default: "18:00:00"
      selector: { time: {} }

mode: restart

trigger:
  # Gatilho 1: Botão ESPHome
  - platform: event
    event_type: esphome.esp_click_event
    id: "trigger_botao"
  # Gatilho 2: Movimento nos Sensores
  - platform: state
    entity_id: !input motion_sensors
    to: "on"
    id: "trigger_movimento"
  # Gatilho 3: Tempo de Esquecimento (Botão)
  - platform: state
    entity_id: !input counter_helper
    for: !input tempo_esquecimento
    id: "trigger_esquecimento"

action:
  - variables:
      entidade_bloqueio: !input block_helper
      entidade_contador: !input counter_helper
      id_botao_esp: !input button_id_input
      maximo_cenas: !input max_scenes
      agora: "{{ now().strftime('%H:%M:%S') }}"
      inicio_dia: !input dia_inicio
      fim_dia: !input dia_fim

  - choose:
      # --- LÓGICA DO BOTÃO ---
      - conditions: 
          - condition: template
            value_template: "{{ trigger.id == 'trigger_botao' and trigger.event.data.button == id_botao_esp }}"
        sequence:
          - choose:
              # Clique Curto: Alterna Cenas e Bloqueia Sensor
              - conditions: "{{ trigger.event.data.type == 'curto' }}"
                sequence:
                  - service: input_boolean.turn_on
                    target: { entity_id: !input block_helper }
                  - service: input_number.set_value
                    target: { entity_id: !input counter_helper }
                    data:
                      value: >
                        {% set atual = states(entidade_contador) | float(0) %}
                        {{ 1 if atual >= maximo_cenas else atual + 1 }}
                  - delay: "00:00:00.05"
                  - service: scene.turn_on
                    target:
                      entity_id: >
                        {% set c = states(entidade_contador) | int %}
                        {% if c == 1 %} !input scene_1
                        {% elif c == 2 %} !input scene_2
                        {% elif c == 3 %} !input scene_3
                        {% elif c == 4 %} !input scene_4
                        {% elif c == 5 %} !input scene_5
                        {% endif %}
              
              # Clique Longo: Desliga e Inicia Inibição
              - conditions: "{{ trigger.event.data.type == 'longo' }}"
                sequence: &off_sequence
                  - service: scene.turn_on
                    target: { entity_id: !input scene_off }
                  - service: input_number.set_value
                    target: { entity_id: !input counter_helper }
                    data: { value: 0 }
                  - service: input_boolean.turn_on # Garante bloqueio durante a saída
                    target: { entity_id: !input block_helper }
                  - delay: !input tempo_inibicao
                  - service: input_boolean.turn_off
                    target: { entity_id: !input block_helper }

      # --- LÓGICA DO SENSOR ---
      - conditions:
          - condition: template
            value_template: "{{ trigger.id == 'trigger_movimento' }}"
          - condition: state
            entity_id: !input block_helper
            state: "off"
        sequence:
          - choose:
              # Dia
              - conditions: "{{ agora >= inicio_dia and agora <= fim_dia }}"
                sequence: [{service: scene.turn_on, target: {entity_id: !input scene_dia}}]
              # Noite (Como no seu código anterior, assume-se Noite/Madrugada se não for Dia)
              - conditions: []
                sequence: [{service: scene.turn_on, target: {entity_id: !input scene_noite}}]
          - delay: { seconds: !input tempo_sensor }
          - service: scene.turn_on
            target: { entity_id: !input scene_off }

      # --- LÓGICA DE ESQUECIMENTO (TIMER DO BOTÃO) ---
      - conditions:
          - condition: template
            value_template: "{{ trigger.id == 'trigger_esquecimento' and states(entidade_contador) | float(0) > 0 }}"
        sequence: *off_sequence
